rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'natandsantosmarinho10@gmail.com' ||
        request.auth.token.email == 'brisasofc@gmail.com' ||
        request.auth.token.email == 'isaacbomfim.00@gmail.com' ||
        request.auth.token.email == 'lucaswelglys@gmail.com'
      );
    }

    // Allow authenticated users to read and write (but not delete) product images, signatures, and delivery photos
    match /products/{allPaths=**} {
      allow read, create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /deliveries/{allPaths=**} {
      allow read, create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /assemblies/{allPaths=**} {
      allow read, create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    // Only allow administrators to manage backups
    match /backups/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    
    // Default deny catch-all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
